{
  "name": "app-auditor-mcp",
  "version": "1.0.0",
  "description": "Production-ready MCP server for automated web application auditing",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "audit",
    "accessibility",
    "performance",
    "seo",
    "security",
    "lighthouse",
    "playwright"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@playwright/test": "^1.48.0",
    "axe-core": "^4.10.0",
    "cheerio": "^1.0.0-rc.12",
    "chrome-launcher": "^1.2.1",
    "date-fns": "^3.6.0",
    "fs-extra": "^11.3.5",
    "lighthouse": "^12.8.2",
    "marked": "^12.0.0",
    "p-limit": "^5.0.0",
    "p-retry": "^6.2.0",
    "puppeteer-core": "^23.0.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
